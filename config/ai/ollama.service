## OLLAMA SERVICE CONFIG BY WEBSTACKUP
# https://github.com/TurboLabIt/webstackup/blob/master/config/ai/ollama.service
#
# This gets activated on install https://github.com/TurboLabIt/webstackup/blob/master/script/ai/ollama-installer.sh
#
# To activate it manually:
#
#  sudo mkdir -p /etc/systemd/system/ollama.service.d
#  sudo ln -s /usr/local/turbolab.it/webstackup/config/ai/ollama.service /etc/systemd/system/ollama.service.d/30-webstackup.conf
#  sudo systemctl daemon-reload && sudo service ollama restart
#
# ⚠ OLLAMA_HOST=0.0.0.0 exposes the (auth-less) API on every interface!
#   On servers with a public IP, firewall port 11434
#
# 📚 https://github.com/ollama/ollama/blob/main/docs/faq.md#how-do-i-configure-ollama-server

[Service]
Environment="OLLAMA_HOST=0.0.0.0"
Environment="OLLAMA_KEEP_ALIVE=30m"
Environment="OLLAMA_FLASH_ATTENTION=1"
Environment="OLLAMA_NUM_PARALLEL=2"
